# Local development only (copy to .env.local — never commit secrets)
# Vercel does NOT read this file; add the same keys in Vercel → Settings → Environment Variables.

# Django API base including /api (used on localhost and by the /api/backend proxy on the server)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Optional on Vercel: server-only Railway URL (same value as NEXT_PUBLIC_API_URL). Helps if you
# prefer not to rely on NEXT_PUBLIC_* for the proxy Route Handler.
# BACKEND_API_BASE_URL=https://YOUR-SERVICE.up.railway.app/api
