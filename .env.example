# =============================================================================
# LOCAL (npm run dev on same PC as Django)
# =============================================================================
# Copy to ".env.local" (gitignored). Point API at your machine:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# =============================================================================
# VERCEL FRONTEND + BACKEND ON YOUR PC (must expose Django publicly)
# =============================================================================
# Browsers cannot reach "localhost" on your laptop from the internet.
# Use ngrok / Cloudflare Tunnel and put the HTTPS URL here (with /api):
# NEXT_PUBLIC_API_URL=https://YOUR-SUBDOMAIN.ngrok-free.app/api
#
# Set the SAME value in Vercel → Settings → Environment Variables (Production
# or Preview). Redeploy after saving.
#
# Optional: server-side proxy also needs the backend URL:
# BACKEND_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app/api
#
# Django .env: add tunnel origin to CORS_EXTRA_ORIGINS and
# CSRF_TRUSTED_ORIGINS_EXTRA (see dmi-backend/.env.example), OR run Django with
# DEBUG=True locally (CORS allows all — demo only).
